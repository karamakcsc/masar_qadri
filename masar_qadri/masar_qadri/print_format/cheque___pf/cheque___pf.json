 "html": "<br><br><br>\n{% set dinar = \"{:,.3f}\".format(doc.amount).split('.')[0] %}\n{% set fills = \"{:,.3f}\".format(doc.amount).split('.')[1] %}\n<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        @page {\n            size: 200mm 75mm !important;\n            margin: 0 !important;\n        }\n        html, body {\n            width: 200mm !important;\n            height: 75mm !important;\n            margin: 0 !important;\n            padding: 0 !important;\n            font-size: 14px !important;\n            direction: rtl;\n        }\n        p {\n            margin: 0;\n            padding: 0;\n        }\n        .text-right {\n            text-align: right;\n        }\n        .text-left {\n            text-align: left;\n        }\n    </style>\n</head>\n<body>\n    <div>\n        <big>\n            <br><br>\n            <p class=\"text-left\" style=\"position: absolute; left: 63mm; top: 12mm; font-size: 14px;\">\n                <b>{{ doc.get_formatted(\"posting_date\") or '' }}</b>\n            </p>\n            \n            <p class=\"text-left\" style=\"position: absolute; left: 170mm; top: 26mm; font-size: 14px;\">\n                <b>{{ doc.pay_order_of or ''}}</b>\n            </p>\n            \n            <p class=\"text-left\" style=\"position: absolute; left: 179mm; top: 37mm; font-size: 14px;\">\n                <b>{{ dinar }}</b>\n            </p>\n            \n            <p class=\"text-left\" style=\"position: absolute; left: 199mm; top: 37mm; font-size: 14px;\">\n                <b>{{ fills }}</b>\n            </p>\n            \n            <p class=\"text-right\" style=\"position: absolute; left: 85mm; top: 32mm; font-size: 11px;\">\n                <b>\n                    {% set whole_part = doc.amount | int %}\n                    {% set decimal_part = ((doc.amount - whole_part) * 1000 ) %}\n                \n                    {{ frappe.utils.in_words(whole_part) }}&nbsp;&nbsp;\u062f\u064a\u0646\u0627\u0631 \u0623\u0631\u062f\u0646\u064a\n                    {% if decimal_part > 0 %}\n                        \u0648 {{ fills  }} \u0641\u0644\u0633\n                    {% endif %}\n                    \u0641\u0642\u0637 \u0644\u0627 \u063a\u064a\u0631\n                </b>\n            </p>\n\n        </big>\n    </div>\n</body>\n</html>",
