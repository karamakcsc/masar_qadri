 "doc_type": "POS Invoice",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<style>\r\n    @page {\r\n        size: 70mm auto;\r\n        margin: 0;\r\n    }\r\n\r\n    body {\r\n        margin: 0;\r\n        padding-left: 2mm;\r\n        padding-right: 0mm;\r\n    }\r\n\r\n    .print-format { \r\n        width: 69mm;\r\n        max-width: 69mm;\r\n        font-family: Arial, sans-serif;\r\n        font-size: 10px;   /* reduced */\r\n        font-weight: bold;\r\n    }\r\n\r\n    .print-format td, \r\n    .print-format th {\r\n        font-size: 9px; /* was 10 */\r\n        font-weight: bold;\r\n        color: #000;\r\n        line-height: 1.0; /* tighter */\r\n        border: none;\r\n        padding: 0.5px;   /* reduced further */\r\n    }\r\n\r\n    .header-section {\r\n        display: flex;\r\n        flex-direction: column;\r\n        margin-bottom: -6px;  /* reduced */\r\n        width: 100%;\r\n        font-size: 9px; \r\n        font-weight: bold;\r\n    }\r\n\r\n    .company-info-row {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        width: 100%;\r\n        align-items: center;\r\n        margin-bottom: -2px; /* reduced spacing */\r\n    }\r\n\r\n    .items-table {\r\n        width: 100%;\r\n        font-size: 7px !important;\r\n        border-collapse: collapse;\r\n        margin: 0.1px 0; /* reduced */\r\n    }\r\n\r\n    .items-table th,\r\n    .items-table td {\r\n        font-size: 7px !important;\r\n        padding: 0.1px;\r\n        vertical-align: top;\r\n        word-wrap: break-word;\r\n    }\r\n\r\n    .items-table th {\r\n        border-bottom: 1px solid #000;\r\n    }\r\n    .barcode {\r\n        width: 14%;\r\n    }\r\n    .item-name { width: 70%; }\r\n    .item-qty { width: 1%; text-align:center; }\r\n    .item-price, .item-discount, .item-amount {\r\n        width: 1%; \r\n        text-align: right;\r\n    }\r\n\r\n    .item-name-text {\r\n        word-break: break-word;\r\n        line-height: 1.0;\r\n    }\r\n\r\n    .total-line td {\r\n        border-top: 1px solid #000;\r\n        font-size: 9px;\r\n        padding: 0.5px;\r\n    }\r\n\r\n    .grand-total td {\r\n        border-top: 2px solid #000;\r\n        font-size: 10px;\r\n        font-weight: bold;\r\n        padding: 1px;\r\n    }\r\n\r\n    .company-header {\r\n        text-align: center;\r\n        font-size: 9px; /* reduced */\r\n        margin-bottom: 2px;\r\n    }\r\n\r\n    .terms {\r\n        font-size: 9px;\r\n        line-height: 1.0;\r\n        margin-top: 2px;\r\n    }\r\n\r\n    .thankyou {\r\n        text-align: center;\r\n        font-size: 9px;\r\n        font-weight: bold;\r\n        margin-top: 3px;\r\n    }\r\n\r\n    .cut-line {\r\n        border-top: 1px dashed #000;\r\n        margin: 10px 0 4px 0; /* reduced height */\r\n        position: relative;\r\n        height: 8px;\r\n    }\r\n\r\n    .cut-line::before {\r\n        content: \"\u2702\";\r\n        position: absolute;\r\n        top: -7px; \r\n        left: 0;\r\n        font-size: 10px;\r\n        background: #fff;\r\n        padding-right: 2px;\r\n    }\r\n</style>\r\n\r\n<!-- Logo -->\r\n{% if letter_head %}\r\n    {{ letter_head }}\r\n{% endif %}\r\n\r\n<!-- Original Print or Copy -->\r\n{% set access_log_doc = frappe.get_all('Access Log', filters={'export_from': 'Sales Invoice',\r\n                                                               'reference_document': doc.name,\r\n                                                               'method': 'Print'}) %}\r\n{% set access_log_count = access_log_doc|length %}\r\n{% if doc.is_return %}\r\n    <div style=\"font-size: 12px; text-align:right\"><b>Return</b></div>\r\n{% elif access_log_count < 1 %}\r\n    <div style=\"font-size: 12px; text-align:right\"><b>Original</b></div>\r\n{% elif access_log_count >= 1 %}\r\n    <div style=\"font-size: 12px; text-align:right\"><b>Copy</b></div>\r\n{% endif %}\r\n\r\n<!-- Variables -->\r\n{% set co_doc = frappe.get_doc(\"Company\", doc.company) %}\r\n{% set user_doc = frappe.get_doc(\"User\", doc.owner) %}\r\n{% if doc.sales_team and (doc.sales_team|length) > 0 and doc.sales_team[0].sales_person %}\r\n    {% set sp_id = doc.sales_team[0].sales_person %}\r\n    {% set emp_id = frappe.db.get_value(\"Sales Person\", sp_id, \"employee\") %}\r\n    {% if emp_id %}\r\n        {% set emp_name = frappe.db.get_value(\"Employee\", emp_id, \"first_name\") %}\r\n    {% endif %}\r\n{% endif %}\r\n\r\n<!-- Branch -->\r\n<p class=\"company-header\">\r\n\t{% if doc.pos_profile %} {{ doc.pos_profile }} {% endif %}\r\n</p>\r\n\r\n<!-- Header -->\r\n<div class=\"header-section\">\r\n    <div class=\"company-info-row\">\r\n        <span class=\"label-left\"><b>{{ _(\"Receipt No\") }}:</b></span>\r\n        <span class=\"value\">{{ doc.name }}</span>\r\n    </div>\r\n    <div class=\"company-info-row\">\r\n        <span class=\"label-left\"><b>{{ _(\"Tax ID\") }}:</b></span>\r\n        <span class=\"value\">{{ co_doc.tax_id }}</span>\r\n    </div>\r\n    <div class=\"company-info-row\">\r\n        <span class=\"label-left\"><b>{{ _(\"Cashier\") }}:</b></span>\r\n        <span class=\"value\">{{ user_doc.full_name }}</span>\r\n    </div>\r\n    <div class=\"company-info-row\">\r\n        <span class=\"label-left\"><b>{{ _(\"Customer\") }}:</b></span>\r\n        <span class=\"value\">{{ doc.customer_name }}</span>\r\n    </div>\r\n    <div class=\"company-info-row\">\r\n        <span class=\"label-left\"><b>{{ _(\"Date\") }}:</b></span>\r\n        <span class=\"value\">{{ doc.get_formatted(\"posting_date\") }} {{ doc.get_formatted(\"posting_time\") }}</span>\r\n    </div>\r\n    {% if doc.sales_team and (doc.sales_team|length) == 1 and doc.sales_team[0].sales_person and doc.sales_team[0].sales_person != \"Sales Team\" %}\r\n        <div class=\"company-info-row\">\r\n            <span class=\"label-left\">{{ _(\"Sales Person\") }}:</span>\r\n            <span class=\"value\">{{ emp_name or frappe.db.get_value(\"Sales Person\", sp_id, \"sales_person_name\") or sp_id }}</span>\r\n        </div>\r\n    {% endif %}\r\n</div>\r\n<div class=\"cut-line\"></div>\r\n\r\n<!-- Items Table -->\r\n<table class=\"items-table\">\r\n\t<thead>\r\n\t\t<tr>\r\n\t\t    <th class=\"barcode\">{{ _(\"Barcode\") }}</th>\r\n\t\t    <!--<th class=\"barcode\">{{ _(\"Color\") }}</th>-->\r\n\t\t    <!--<th class=\"barcode\">{{ _(\"Size\") }}</th>-->\r\n\t\t\t<th class=\"item-name\">{{ _(\"Item\") }}</th>\r\n\t\t\t<th class=\"item-qty\">{{ _(\"Qty\") }}</th>\r\n\t\t\t<th class=\"item-price\">{{ _(\"Price\") }}</th>\r\n\t\t\t<th class=\"item-discount\">{{ _(\"Disc\") }}</th>\r\n\t\t\t<th class=\"item-amount\">{{ _(\"Amt\") }}</th>\r\n\t\t</tr>\r\n\t</thead>\r\n\t<tbody>\r\n\t    {% set total_org_price = namespace(value=0) %}\r\n        {% set total_discount = namespace(value=0) %}\r\n\t\t{%- for item in doc.items -%}\r\n\t\t    {% set item_doc = frappe.get_doc(\"Item\", item.item_code) %}\r\n\t\t    {% set color = namespace(value=\"\") %}\r\n\t\t    {% set size = namespace(value=0) %}\r\n\t\t    {% set  color.value = frappe.db.get_value(\"Item Variant Attribute\", {\"attribute\": \"Color\", \"parent\": item.item_code}, \"attribute_value\") %}\r\n\t\t    {% set  color.value = frappe.db.get_value(\"Item Variant Attribute\", {\"attribute\": \"Size\", \"parent\": item.item_code}, \"attribute_value\") %}\r\n\t\t    {% set total_org_price.value = total_org_price.value + (item.price_list_rate * item.qty) %}\r\n            {% set total_discount.value = total_discount.value + item.discount_amount %}\r\n    \t\t<tr>\r\n    \t\t    <td class=\"barcode\">{{ item.barcode }}</td>\r\n    \t\t    <!--<td class=\"barcode\">{{ color.value }}</td>-->\r\n    \t\t    <!--<td class=\"barcode\">{{ size.value }}</td>-->\r\n    \t\t\t<td class=\"item-name\">\r\n    \t\t\t\t<div class=\"item-name-text\">{{ item.item_name }}</div>\r\n    \t\t\t</td>\r\n    \t\t\t<td class=\"item-qty\">{{ item.qty }}</td>\r\n    \t\t\t<td class=\"item-price\">{{ item.price_list_rate }}</td>\r\n    \t\t\t<td class=\"item-discount\">{{ item.discount_amount }}</td>\r\n    \t\t\t<td class=\"item-amount\">{{ item.amount }}</td>\r\n    \t\t\t<!--<td class=\"item-price\">{{ item.get_formatted(\"price_list_rate\") }}</td>-->\r\n    \t\t\t<!--<td class=\"item-discount\">{{ item.get_formatted(\"discount_amount\") }}</td>-->\r\n    \t\t\t<!--<td class=\"item-amount\">{{ item.get_formatted(\"amount\") }}</td>-->\r\n    \t\t</tr>\r\n\t\t{%- endfor -%}\r\n\t</tbody>\r\n</table>\r\n\r\n<!-- Totals Table -->\r\n<table class=\"totals-table\" style=\"width:100%;\">\r\n    <!-- Total Quantity -->\r\n    <tr class=\"total-line\">\r\n        <td class=\"text-right\">{{ _(\"Total Qty\") }}:</td>\r\n        <td class=\"text-right\">{{ doc.get_formatted(\"total_qty\", doc) }}</td>\r\n    </tr>\r\n\r\n    {% if doc.is_return == 0 %}\r\n        <!-- Original Price -->\r\n        <tr class=\"total-line\">\r\n            <td class=\"text-right\">{{ _(\"Original Price\") }}:</td>\r\n            <td class=\"text-right\">{{ frappe.format_value(total_org_price.value, \"Currency\") }}</td>\r\n        </tr>\r\n\r\n        <!-- Combined Discount (Items + Invoice) -->\r\n        {% set combined_discount = total_discount.value + (doc.discount_amount or 0) %}\r\n        {% if combined_discount > 0 %}\r\n            <tr class=\"total-line\">\r\n                <td class=\"text-right\">{{ _(\"Total Discount\") }}:</td>\r\n                <td class=\"text-right\">-{{ frappe.format_value(combined_discount, \"Currency\") }}</td>\r\n            </tr>\r\n        {% endif %}\r\n        \r\n        <!-- Tax -->\r\n        {% if doc.total_taxes_and_charges %}\r\n            <tr class=\"total-line\">\r\n                <td class=\"text-right\">{{ _(\"Tax\") }}:</td>\r\n                <td class=\"text-right\">{{ doc.get_formatted(\"total_taxes_and_charges\", doc) }}</td>\r\n            </tr>\r\n        {% endif %}\r\n\r\n        <!-- Net Total -->\r\n        <tr class=\"total-line\">\r\n            <td class=\"text-right\">{{ _(\"Net Total\") }}:</td>\r\n            <td class=\"text-right\">{{ doc.get_formatted(\"net_total\", doc) }}</td>\r\n        </tr>\r\n\r\n        <!-- Mode of Payments -->\r\n        {% if doc.payments and (doc.payments|length) > 0 %}\r\n            <!--<tr class=\"total-line\">-->\r\n            <!--    <td colspan=\"2\"><b>{{ _(\"Payments\") }}</b></td>-->\r\n            <!--</tr>-->\r\n            {% for pay in doc.payments %}\r\n                {% if pay.amount %}\r\n                    <tr class=\"total-line\"> \r\n                    \t{% if pay.type == \"Cash\" %} \r\n                    \t\t<td class=\"text-right\">{{ _(\"Cash\") }}:</td> \r\n                    \t\t<td class=\"text-right\">{{ frappe.format_value(pay.amount, \"Currency\") }}</td> \r\n                    \t{% elif pay.type == \"Bank\"%} \r\n                    \t    <td class=\"text-right\">{{ _(\"Credit Card\") }}:</td> \r\n                    \t\t<td class=\"text-right\">{{ frappe.format_value(pay.amount, \"Currency\") }}</td> \r\n                    \t{% else %}\r\n                    \t\t<td class=\"text-right\">{{ pay.mode_of_payment }}:</td> \r\n                    \t\t<td class=\"text-right\">{{ frappe.format_value(pay.amount, \"Currency\") }}</td> \r\n                    \t{% endif %} \r\n                    </tr>\r\n                {% endif %}\r\n            {% endfor %}\r\n        {% endif %}\r\n        \r\n         <!-- Paid Amount -->\r\n        {% if doc.paid_amount %}\r\n            <tr class=\"total-line\">\r\n                <td class=\"text-right\">{{ _(\"Paid Amount\") }}:</td>\r\n                <td class=\"text-right\">{{ doc.get_formatted(\"paid_amount\", doc) }}</td>\r\n            </tr>\r\n        {% endif %}\r\n    \r\n        <!-- Change Amount -->\r\n        {% if doc.change_amount %}\r\n            {% if (doc.paid_amount - doc.grand_total) == doc.change_amount %}\r\n                <tr class=\"total-line\">\r\n                    <td class=\"text-right\">{{ _(\"Change\") }}:</td>\r\n                    <td class=\"text-right\">{{ doc.get_formatted(\"change_amount\", doc) }}</td>\r\n                </tr>\r\n            {% else %}\r\n                <tr class=\"total-line\">\r\n                    <td class=\"text-right\">{{ _(\"Change\") }}:</td>\r\n                    <td class=\"text-right\">{{ frappe.format_value((doc.paid_amount - doc.grand_total), \"Currency\") }}</td>\r\n                </tr>\r\n            {% endif %}\r\n        {% endif %}\r\n    {% endif %}\r\n\r\n    <!-- Grand Total -->\r\n    <tr class=\"grand-total\">\r\n        <td class=\"text-right\">{{ _(\"Grand Total\") }}:</td>\r\n        <td class=\"text-right\">{{ doc.get_formatted(\"grand_total\", doc) }}</td>\r\n    </tr>\r\n</table>\r\n\r\n<!-- Terms -->\r\n<p class=\"terms\">{{ doc.terms or \"\" }}</p>\r\n\r\n<!-- Thank You -->\r\n<p class=\"thankyou\">{{ _(\"Thank you, visit us again.\") }}</p>\r\n\r\n<!-- Customer Details & Signature -->\r\n{% if doc.is_return %}\r\n    <div style=\"margin-top: 15px; font-size: 11px; border-top: 1px solid #000; padding-top: 8px;\">\r\n        <div style=\"margin-bottom: 5px;\">\r\n            <b>{{ _(\"Customer Name\") }}:</b> {{ doc.customer_name or \"\" }}\r\n        </div>\r\n        <div style=\"margin-bottom: 5px;\">\r\n            <b>{{ _(\"Customer Mobile No\") }}:</b> \r\n            {{ frappe.db.get_value(\"Customer\", doc.customer, \"mobile_no\") or \"\" }}\r\n        </div>\r\n        <div style=\"margin-top: 20px;\">\r\n            <b>{{ _(\"Customer Signature\") }}:</b>\r\n            <div style=\"border-bottom: 1px solid #000; width: 200px; height: 30px;\"></div>\r\n        </div>\r\n    </div>\r\n{% endif %}\r\n\r\n<!-- QR Code -->\r\n{% if doc.custom_qr_code %}\r\n    <div style=\"text-align: center; margin-top: 10px;\">\r\n        <img src=\"{{ doc.custom_qr_code }}\"\r\n             alt=\"QR Code\"\r\n             style=\"width: 120px; height: 120px; object-fit: contain;\" />\r\n    </div>\r\n{% endif %}",
